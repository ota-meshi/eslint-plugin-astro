{
  "name": "eslint-plugin-astro",
  "version": "2.0.0",
  "description": "ESLint plugin for Astro component",
  "type": "module",
  "main": "lib/index.mjs",
  "types": "lib/index.d.mts",
  "exports": {
    ".": {
      "types": "./lib/index.d.mts",
      "import": "./lib/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": "^22.22.3 || ^24.16.0 || >=26.3.0"
  },
  "scripts": {
    "prebuild": "npm run -s clean",
    "build": "npm run build:tsdown",
    "build:tsdown": "tsdown",
    "clean": "rimraf .nyc_output dist coverage",
    "test": "npm run mocha -- \"tests/src/**/*.ts\" --reporter dot --timeout 60000",
    "test:integration": "npm run build && npm run test:integration-wo-build",
    "test:integration-wo-build": "npm run mocha -- \"tests/integration/**/*.ts\" --reporter dot --timeout 60000",
    "test:type": "tsc --noEmit",
    "cover": "nyc --reporter=lcov npm run test",
    "debug": "npm run mocha -- \"tests/src/**/*.ts\" --reporter dot --timeout 60000",
    "lint": "npm run lint:js && npm run lint:ts",
    "prelint:js": "npm run build:tsdown",
    "lint:js": "eslint . --ignore-pattern=\"tests/fixtures/integration/*/src/\"",
    "lint:ts": "tsc --noEmit",
    "preeslint-fix": "npm run build:tsdown",
    "eslint-fix": "eslint . --ignore-pattern=\"tests/fixtures/integration/*/src/\" --fix",
    "update": "npm run ts -- ./tools/update.ts",
    "new": "npm run ts -- ./tools/new-rule.ts",
    "docs:dev": "astro dev",
    "docs:build": "astro build",
    "docs:setup": "node ./docs-build/setup-docs.mjs",
    "docs:preview": "astro preview",
    "preversion": "npm test && git add .",
    "version": "env-cmd -e version -- npm run update && git add .",
    "version:ci": "changeset version && env-cmd -e version -- npm run update && git add --all",
    "prerelease": "npm run build",
    "release": "changeset publish",
    "ts": "tsx",
    "mocha": "npm run ts -- ./node_modules/mocha/bin/mocha.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ota-meshi/eslint-plugin-astro.git"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "astro",
    "astrojs"
  ],
  "author": "Yosuke Ota (https://github.com/ota-meshi)",
  "funding": "https://github.com/sponsors/ota-meshi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ota-meshi/eslint-plugin-astro/issues"
  },
  "homepage": "https://ota-meshi.github.io/eslint-plugin-astro/",
  "dependencies": {
    "@eslint-community/eslint-utils": "^4.5.1",
    "@jridgewell/sourcemap-codec": "^1.5.0",
    "@typescript-eslint/types": "^8.61.0",
    "astro-eslint-parser": "^2.0.0",
    "espree": "^11.0.0",
    "globals": "^17.0.0",
    "postcss": "^8.5.3",
    "postcss-selector-parser": "^7.1.0"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": ">=8.61.0",
    "eslint": ">=10.0.0",
    "eslint-plugin-jsx-a11y": ">=6.10.2"
  },
  "peerDependenciesMeta": {
    "@typescript-eslint/parser": {
      "optional": true
    },
    "eslint-plugin-jsx-a11y": {
      "optional": true
    }
  },
  "devDependencies": {
    "@actions/github": "^9.0.0",
    "@astrojs/compiler": "^4.0.0",
    "@astrojs/markdown-satteri": "0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/svelte": "^9.0.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.24.2",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.3.0",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^10.0.0",
    "@eslint/json": "^2.0.0",
    "@ota-meshi/eslint-plugin": "^0.20.0",
    "@types/eslint-scope": "^9.0.0",
    "@types/eslint-utils": "^3.0.1",
    "@types/estree": "1.0.9",
    "@types/less": "^3.0.3",
    "@types/mocha": "^10.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/stylus": "^0.48.38",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "assert": "^2.0.0",
    "astro": "^7.0.0",
    "env-cmd": "^11.0.0",
    "esbuild": "^0.28.0",
    "esbuild-register": "^3.3.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-astro": "^2.0.0",
    "eslint-plugin-eslint-plugin": "^7.0.0",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-json-schema-validator": "^6.0.0",
    "eslint-plugin-jsonc": "^3.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-n": "^18.0.0",
    "eslint-plugin-node-dependencies": "^2.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "eslint-plugin-yml": "^3.0.0",
    "expect-type": "^1.0.0",
    "js-yaml": "^5.0.0",
    "less": "^4.1.2",
    "mocha": "^11.0.0",
    "monaco-editor": "^0.55.0",
    "nyc": "^18.0.0",
    "pako": "^2.0.4",
    "postcss-nested": "^7.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-svelte": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "rimraf": "^6.0.0",
    "sass": "^1.52.2",
    "stylus": "^0.64.0",
    "svelte": "^5.0.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.61.0",
    "vite-plugin-eslint4b": "^0.8.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
